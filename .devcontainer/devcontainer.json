{
  "containerEnv": {
    "EXTERNALLY-MANAGED": "false"
    // "POETRY_VIRTUALENVS_IN_PROJECT": "true"
  },
  "name": "openmotics/home-assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "postCreateCommand": "bash .devcontainer/build.sh",
  "mounts": ["source=homeassistant-config,target=/config,type=volume"],
  // Forward the HA HTTP port and open a browser automatically when it appears.
  "forwardPorts": [8123],
  "portsAttributes": {
    "8123": {
      "label": "Home Assistant",
      "onAutoForward": "notify"
    }
  },
  // VS Code recommendations and per-workspace settings.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "GitHub.vscode-pull-request-github",
        "charliermarsh.ruff",
        "GitHub.vscode-github-actions",
        "ryanluker.vscode-coverage-gutters",
        "tamasfe.even-better-toml",
        // Optional: Docker tooling (handy for logs/inspecting)
        "ms-azuretools.vscode-docker",
        // EditorConfig support
        "editorconfig.editorconfig"
      ]
    }
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/ruff:1": {}
    // "ghcr.io/devcontainers/features/go:1": {}
    // "ghcr.io/devcontainers/features/node:1": {},
    // "ghcr.io/devcontainers/features/rust:1": {}
  }
}
