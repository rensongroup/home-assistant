{
  "containerEnv": {
    "EXTERNALLY-MANAGED": "false"
    // "POETRY_VIRTUALENVS_IN_PROJECT": "true"
  },
  "name": "openmotics/home-assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "postCreateCommand": "bash .devcontainer/build.sh",
  "mounts": ["source=homeassistant-config,target=/config,type=volume"],
  // Forward the HA HTTP port and open a browser automatically when it appears.
  "forwardPorts": [8123],
  "portsAttributes": {
    "8123": {
      "label": "Home Assistant",
      "onAutoForward": "notify"
    }
  },
  // VS Code recommendations and per-workspace settings.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python", // Base Python support (interpreter, debugging)
        "ms-python.debugpy", // Python debugger
        // "ms-python.vscode-pylance", // IntelliSense, type hints (until ty has IDE plugin)
        "charliermarsh.ruff", // Ruff: single tool for linting + formatting
        "GitHub.vscode-pull-request-github",
        "GitHub.vscode-github-actions",
        "meta.pyrefly", // Pyrefly: AI code completion
        "ms-python.vscode-python-envs", // Python environment management
        "tamasfe.even-better-toml", // TOML support for pyproject.toml
        "editorconfig.editorconfig", // EditorConfig support
        "eamodio.gitlens" // Git supercharged
      ]
    }
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    // "ghcr.io/devcontainers/features/go:1": {},
    // "ghcr.io/devcontainers/features/node:1": {},
    // "ghcr.io/devcontainers/features/rust:1": {},
    // "ghcr.io/siri404/devcontainer-ai-features/gemini-cli:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/ruff:1": {}
  }
}
