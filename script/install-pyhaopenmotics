#!/bin/bash

# script/install-pyhaopenmotics: Install pyhaopenmotics dependencies
#
# Installs the pyhaopenmotics package and its dependencies in the current environment.
#
# Usage:
#   ./script/install-pyhaopenmotics
#
# Examples:
#  ./script/install-pyhaopenmotics
#  ./script/install-pyhaopenmotics -b main -v 0.1.0
#  ./script/install-pyhaopenmotics -b feature-branch
# ./script/install-pyhaopenmotics -v 0.2.0

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

if [[ -z ${VIRTUAL_ENV:-} ]]; then
    log_header "Activating virtual environment"
    # shellcheck source=/dev/null
    if [[ -f "$HOME/.local/ha-venv/bin/activate" ]]; then
        source "$HOME/.local/ha-venv/bin/activate"
    elif [[ -f "$PWD/.local/ha-venv/bin/activate" ]]; then
        source "$PWD/.local/ha-venv/bin/activate"
    else
        log_error "Virtual environment not found in $HOME/.local/ha-venv or $PWD/.local/ha-venv"
        exit 1
    fi
fi

BRANCH=""
VERSION=""

# Parse  flags
INSTALL_ARGS=()


while [[ $# -gt 0 ]]; do
    case $1 in
        -b)
            BRANCH="$2"
            shift 2
            ;;
        -v)
            VERSION="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

URL="pyhaopenmotics@git+https://github.com/rensongroup/pyhaopenmotics.git"

if [ ! -z "$BRANCH" ]; then
    URL="${URL}@${BRANCH}"
else
    URL="${URL}@main"
fi

if [ ! -z "$VERSION" ]; then
    URL="${URL}#pyhaopenmotics==${VERSION}"
fi

log_header "Installing pyhaopenmotics from $URL"

# Check if pyhaopenmotics is installed
if ! python -c "import pyhaopenmotics" 2>/dev/null; then
    log_info "old pyhaopenmotics installation found. Removing..."
    uv pip uninstall pyhaopenmotics
fi
echo ""

log_info "Installing pyhaopenmotics $VERSION ..."
uv pip install "$URL"

# Clean up any accidental package installation from pytest/test dependencies
# This prevents Home Assistant from loading the installed version instead of
# the development version from custom_components/
"$SCRIPT_DIR/clean" --minimal
