{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Home Assistant on port 8123",
      "type": "shell",
      "command": "scripts/run-ha",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "logs"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "pytest --durations=10 --cov-report term-missing --cov=custom_components.openmotics tests",
      "problemMatcher": []
    },
    {
      "label": "Run pre-commit hook",
      "type": "shell",
      "command": "prek run --all-files",
      "problemMatcher": []
    }
  ]
}
